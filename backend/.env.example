# ===== kefuxitong 后端环境变量 =====
# 复制为 .env 后填写真实值。.env 不入库。

# 数据库（默认 SQLite，无需改动）
# DATABASE_URL=sqlite:///./data/kefuxitong.db

# JWT 密钥（生产环境务必改为随机长字符串）
SECRET_KEY=dev-secret-change-me-to-a-long-random-string

# 默认管理员（首次启动自动创建）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ===== LLM 配置（核心：填上 API_KEY 才启用真实 AI）=====
# 三选一（都兼容 OpenAI 接口）：

# --- DeepSeek（推荐，便宜）---
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# --- 通义千问 ---
# LLM_API_KEY=
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus

# --- OpenAI ---
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# LLM 调用参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=60

# 训练对话轮数限制
MAX_DIALOGUE_TURNS=20
MIN_DIALOGUE_TURNS=4
